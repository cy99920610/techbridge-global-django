# Copy to .env for local development (never commit .env)

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Production only — PostgreSQL (Render, Railway, etc. provide this automatically)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Production only — trusted domains for CSRF (comma-separated, include https://)
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Optional — persistent logo/media uploads in production (free tier at cloudinary.com)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
